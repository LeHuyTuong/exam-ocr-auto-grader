# ⚠️ LIÊN QUAN BẢO MẬT ⚠️
# File này là template cho local development. KHÔNG chứa secrets thật.
# Điền giá trị thực tế vào .env (đã nằm trong .gitignore).
# Trên production: secrets được inject qua server env vars hoặc GitHub Secrets.

APP_NAME="Hệ thống chấm thi"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_URL=http://localhost

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log

# ===== THIRD-PARTY API KEYS =====
# Điền keys khi cần cho local dev. Để trống trên production — inject qua env.

CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

GEMINI_MODEL=gemini-flash-latest
GEMINI_API_KEY=

GROQ_API_KEY=
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

OPENROUTER_API_KEY=
OPENROUTER_VISION_MODEL=google/gemma-4-31b-it:free

CEREBRAS_API_KEY=
MISTRAL_API_KEY=
MISTRAL_VISION_MODEL=mistral-small-latest

JWT_SECRET=
JWT_ALGO=HS256

# ===== SEEDER CREDENTIALS (local dev only) =====
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_TEACHER_EMAIL=
SEED_TEACHER_PASSWORD=

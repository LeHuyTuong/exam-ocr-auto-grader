APP_NAME="Hệ thống chấm thi"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_URL=http://localhost

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log

# Lưu ảnh bài thi. Cách đơn giản nhất: dùng 1 biến CLOUDINARY_URL
# (lấy trong Dashboard Cloudinary → Account Details → "API environment variable").
# Dạng: cloudinary://<api_key>:<api_secret>@<cloud_name>
# Nếu để trống, upload ảnh sẽ bị bỏ qua (chấm điểm vẫn chạy, chỉ không lưu ảnh).
CLOUDINARY_URL=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
